# Base configuration — committed, no secrets here.
# Sensitive or local overrides go in .env (gitignored).

# Runtime mode: production | dev | mock | test
ORGANISM_MODE=dev

# Mind adapter (LM Studio)
MIND_BASE_URL=http://localhost:1234
MIND_MODEL=hermes-3-llama-3.2-3b

# Timing (milliseconds)
HEARTBEAT_INTERVAL_MS=5000
BREATH_INTERVAL_MS=30000

# History limits — lowered in test scripts to make trim branches reachable
HEARTBEAT_MAX_HISTORY=100
BREATH_MAX_HISTORY=50
