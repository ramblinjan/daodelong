{
  "name": "daodelong",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names heartbeat,engine,face --prefix-colors cyan,green,magenta \"pnpm heartbeat\" \"pnpm engine\" \"pnpm face\"",
    "heartbeat": "tsx apps/engine/src/bootstrap.ts",
    "engine": "tsx apps/engine/src/breath.ts",
    "face": "tsx apps/face/src/server.ts",
    "test": "node --test --import tsx/esm tests/lifecycle.yin.test.ts tests/lifecycle.yang.test.ts",
    "test:yin": "node --test --import tsx/esm tests/lifecycle.yin.test.ts",
    "test:yang": "node --test --import tsx/esm tests/lifecycle.yang.test.ts"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.21.0"
  }
}
